# Supabase (Free tier - https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (Free tier - 100 emails/day - https://resend.com)
RESEND_API_KEY=your_resend_api_key

# Your company email (for sending)
FROM_EMAIL=marketing@madeinteriors.ae
ADMIN_EMAIL=marketing@madeinteriors.ae

# App URL (change to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SECURITY SETTINGS (REQUIRED FOR PRODUCTION)
# ============================================

# API Secret Key - Required for dashboard API access
# Generate with: openssl rand -hex 32
API_SECRET_KEY=your_api_secret_key_here

# Cron Secret - Required for scheduled job authentication
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Allowed Origins for CORS (comma-separated)
# Example: https://madeinteriors.ae,https://www.madeinteriors.ae
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting (optional)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
